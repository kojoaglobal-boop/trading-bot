{
  "name": "cross-market-trading-bot",
  "version": "0.1.0",
  "private": true,
  "description": "Paper-first cross-market trading bot scaffold for crypto meme coins, stocks, futures, and forex.",
  "type": "module",
  "scripts": {
    "backtest": "node src/cli.js backtest --sample",
    "paper": "node src/cli.js paper --ticks 200",
    "doctor": "node src/cli.js doctor",
    "optimize": "node src/cli.js optimize --sample",
    "walk-forward": "node src/cli.js walk-forward --sample",
    "sources": "node src/cli.js sources",
    "journal": "node src/cli.js journal",
    "journal:db": "node src/cli.js journal --db",
    "dashboard": "node src/cli.js dashboard",
    "alpaca:account": "node src/cli.js alpaca account",
    "alpaca:bars": "node src/cli.js alpaca bars --symbols AAPL,TSLA,NVDA",
    "alpaca:orders": "node src/cli.js alpaca orders",
    "alpaca:positions": "node src/cli.js alpaca positions",
    "alpaca:fills": "node src/cli.js alpaca fills",
    "alpaca:sync": "node src/cli.js alpaca sync",
    "alpaca:smoke-order": "node src/cli.js alpaca smoke-order --confirm-paper",
    "alpaca:paper-loop": "node src/cli.js alpaca paper-loop --symbols AAPL,TSLA,NVDA --db",
    "scheduler:once": "node src/cli.js scheduler run-once --symbols AAPL,TSLA,NVDA --confirm-paper",
    "scheduler:scalp": "node src/cli.js scheduler run-once --profile scalp --symbols AAPL,TSLA,NVDA --confirm-paper",
    "scheduler:loop": "node src/cli.js scheduler loop --symbols AAPL,TSLA,NVDA --confirm-paper --interval-minutes 60",
    "scheduler:scalp-loop": "node src/cli.js scheduler loop --profile scalp --symbols AAPL,TSLA,NVDA --confirm-paper",
    "oanda:account": "node src/cli.js oanda account",
    "oanda:instruments": "node src/cli.js oanda instruments",
    "oanda:xau": "node src/cli.js oanda candles --instrument XAU_USD --db",
    "finnhub:news": "node src/cli.js finnhub news --symbol TSLA --limit 5",
    "crypto:coinbase": "node src/cli.js crypto bars --provider coinbase --product BTC-USD --db",
    "crypto:kraken": "node src/cli.js crypto bars --provider kraken --pair BTC/USD --db",
    "crypto:quality": "node src/cli.js crypto quality --symbol BTC/USD --db",
    "excel:export": "node src/cli.js export paper-ledger",
    "db": "node src/cli.js db",
    "db:up": "docker compose up -d db",
    "db:status": "docker compose ps",
    "db:schema": "docker compose exec -T db psql -U trading_bot -d trading_bot -f /docker-entrypoint-initdb.d/001_schema.sql",
    "db:down": "docker compose down",
    "test": "node --test"
  },
  "engines": {
    "node": ">=20"
  },
  "license": "UNLICENSED",
  "dependencies": {
    "pg": "^8.22.0"
  }
}
